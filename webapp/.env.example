# =============================================================================
# EU AI Act Compliance Tool - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=euaiact
POSTGRES_USER=euaiact_user
POSTGRES_PASSWORD=your_secure_password_here

# Full connection string (used by backend)
DATABASE_URL=postgresql://euaiact_user:your_secure_password_here@postgres:5432/euaiact

# -----------------------------------------------------------------------------
# Backend Configuration
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=4000

# JWT Configuration
# Generate a secure secret: openssl rand -base64 64
JWT_SECRET=your_jwt_secret_here_minimum_32_characters_recommended_64
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Email Configuration (Optional - for notifications)
# -----------------------------------------------------------------------------
# SMTP server settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# Email sender information
EMAIL_FROM_NAME=EU AI Act Compliance Tool
EMAIL_FROM_ADDRESS=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# Frontend Configuration
# -----------------------------------------------------------------------------
# API URL (for production builds)
VITE_API_URL=http://localhost/api

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
# Bcrypt salt rounds (higher = more secure but slower)
BCRYPT_SALT_ROUNDS=12

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=combined

# -----------------------------------------------------------------------------
# Optional: External Services
# -----------------------------------------------------------------------------
# Sentry DSN for error tracking (optional)
# SENTRY_DSN=https://your_sentry_dsn_here

# Redis URL for session caching (optional, for production)
# REDIS_URL=redis://localhost:6379
